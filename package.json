{
  "name": "@voxpelli/eslint-formatter-summary",
  "version": "5.0.0",
  "description": "ESLint summary formatter aggregating results by rule",
  "author": "Pelle Wessman <pelle@kodfabrik.se> (https://kodfabrik.se/)",
  "contributors": [
    "Marton Hipszki <mhipszki@gmail.com>"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/voxpelli/eslint-formatter-summary.git"
  },
  "bugs": {
    "url": "https://github.com/voxpelli/eslint-formatter-summary/issues"
  },
  "type": "module",
  "exports": "./index.cjs",
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24.0.0",
    "typescript": ">=5.9"
  },
  "files": [
    "index.cjs",
    "lib/*.js"
  ],
  "scripts": {
    "check:installed-check": "installed-check -i @voxpelli/eslint-config",
    "check:knip": "knip",
    "check:lint": "eslint lib/ index.cjs",
    "check:tsc": "tsc",
    "check:type-coverage": "type-coverage --detail --strict --at-least 99",
    "check": "run-p check:*",
    "husky-enable": "husky",
    "husky-disable": "git config --unset core.hooksPath",
    "test-ci": "run-s test:*",
    "test:node": "c8 --reporter=lcov --reporter=text node --test test/*.test.js",
    "test:real-world": "eslint -f ./index.cjs lib/",
    "test": "run-s check test:*",
    "try": "eslint -f ./index.cjs"
  },
  "keywords": [
    "eslint",
    "eslint-formatter",
    "summary",
    "formatter",
    "javascript",
    "linting",
    "report"
  ],
  "dependencies": {
    "chalk": "^5.1.2",
    "terminal-link": "^5.0.0"
  },
  "peerDependencies": {
    "eslint": ">=9.13.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@voxpelli/eslint-config": "^23.0.0",
    "@voxpelli/tsconfig": "^16.2.1",
    "c8": "^11.0.0",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "installed-check": "^10.0.1",
    "knip": "^6.4.1",
    "npm-run-all2": "^8.0.4",
    "type-coverage": "^2.29.7",
    "typescript": "~6.0.2",
    "validate-conventional-commit": "^1.0.4"
  }
}
